{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\Users\Administrator\\.codex\\diegin\\hooks\\diegin_session_start.ps1\"",
            "statusMessage": "Diegin SessionStart",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\Users\Administrator\\.codex\\diegin\\hooks\\diegin_pre_tool.ps1\"",
            "statusMessage": "Diegin PreToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\Users\Administrator\\.codex\\diegin\\hooks\\diegin_pre_reply.ps1\"",
            "statusMessage": "Diegin UserPromptInject",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\Users\Administrator\\.codex\\diegin\\hooks\\diegin_post_tool.ps1\"",
            "statusMessage": "Diegin PostToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\Users\Administrator\\.codex\\diegin\\hooks\\diegin_stop.ps1\"",
            "statusMessage": "Diegin StopReport",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
